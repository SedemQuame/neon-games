#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [[ -z "${REPO_ROOT}" ]]; then
  echo "[pre-push] Failed to determine repository root." >&2
  exit 1
fi

APP_DIR="${REPO_ROOT}/game_trader_app"
if [[ ! -d "${APP_DIR}" ]]; then
  echo "[pre-push] Skipping web build: ${APP_DIR} does not exist."
  exit 0
fi

if ! command -v flutter >/dev/null 2>&1; then
  echo "[pre-push] Flutter SDK not found on PATH. Install Flutter before pushing." >&2
  exit 1
fi

BUILD_OUTPUT="$(mktemp -d "${REPO_ROOT}/.git/prepush-web-build.XXXXXX")"
cleanup() {
  rm -rf "${BUILD_OUTPUT}"
}
trap cleanup EXIT

echo "[pre-push] Building Flutter web release..."
(
  cd "${APP_DIR}"
  flutter build web --release --output "${BUILD_OUTPUT}"
)
echo "[pre-push] Flutter web release build succeeded."
