# =============================================================================
# Glory Grid API — production environment
# Copy these key/value pairs into your hosting provider's environment variable UI.
# Use inline PEM contents for JWT keys; do not rely on mounted secret files.
# =============================================================================

APP_ENV=production
GATEWAY_PORT=80
START_EMBEDDED_REDIS=true

# --- Core runtime ---
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/?appName=glory-grid
REDIS_PASSWORD=replace_with_a_strong_password
INTERNAL_SERVICE_KEY=replace_with_a_strong_internal_secret
CORS_ALLOWED_ORIGINS=https://app.example.com

# --- JWT (inline PEM contents) ---
JWT_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_ISSUER=gamehub-auth
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7

# --- Service ports ---
AUTH_SERVICE_PORT=8001
GAME_SESSION_PORT=8002
PAYMENT_GATEWAY_PORT=8003
WALLET_SERVICE_PORT=8004
TRADER_POOL_PORT=8005

# --- Auth / password reset ---
RESEND_API_KEY=
EMAIL_FROM=Glory Grid Support <support@example.com>
PASSWORD_RESET_URL=https://app.example.com/reset-password
PASSWORD_RESET_TTL_MINUTES=30
OTP_TTL_MINUTES=5

# --- Game session / trader queue ---
TRADE_ORDER_QUEUE=trade:orders
GAME_OUTCOME_PREFIX=game:outcome
GAME_STALE_SWEEP_INTERVAL_SECONDS=20
GAME_STALE_REFUND_SECONDS=90
MIN_SETTLE_MS=1500
MAX_SETTLE_MS=4500

# --- Flutterwave / MoMo ---
FLUTTERWAVE_SECRET_KEY=replace_me
FLUTTERWAVE_WEBHOOK_SECRET=replace_me
FLUTTERWAVE_MOMO_CALLBACK_URL=https://api.example.com/webhooks/payment/flutterwave
FLUTTERWAVE_TRANSFER_CALLBACK_URL=https://api.example.com/webhooks/payment/flutterwave/withdrawal
MOMO_ALLOWED_CHANNELS=mtn-gh,vodafone-gh,airteltigo-gh
MOMO_DEFAULT_CURRENCY=GHS

# --- Tatum / crypto ---
TATUM_API_KEY=replace_me
TATUM_WEBHOOK_SECRET=replace_me
TATUM_BTC_XPUB=replace_me
TATUM_ETH_XPUB=replace_me
TATUM_TRON_XPUB=replace_me
TATUM_TESTNET=false
CRYPTO_WATCHER_INTERVAL_SECONDS=60
CRYPTO_WEBHOOK_URL=https://api.example.com/webhooks/payment/crypto

# --- Deriv ---
DERIV_APP_ID=replace_me
DERIV_WS_URL=wss://ws.binaryws.com/websockets/v3
DERIV_SYMBOL=R_50
DERIV_ACCOUNT_1_TOKEN=replace_me

# --- Trader pool economics ---
BOUNCE_RATE=0.0
PROFIT_TARGET_USD=0.0
WIN_RAKE_RATE=0.0
PAYOUT_MULTIPLIER=1.9
DEPOSIT_FEE_RATE=0.0
WITHDRAWAL_FEE_RATE=0.05
