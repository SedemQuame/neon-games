# =============================================================================
# Glory Grid API — all-in-one container environment template
# Copy this file to .env and fill in real values. NEVER commit .env to git.
# =============================================================================

# --- Runtime ---
APP_ENV=development
LOG_LEVEL=info
GATEWAY_PORT=80
START_EMBEDDED_REDIS=true

# --- MongoDB (external / Atlas) ---
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/?appName=glory-grid

# --- Redis (embedded by default inside the all-in-one container) ---
REDIS_PASSWORD=change_me_in_production
REDIS_ADDR=127.0.0.1:6379
# If you disable embedded Redis, you can use REDIS_URL or REDISHOST/REDISPORT/REDISPASSWORD.

# --- JWT (mounted into /app/secrets inside the container) ---
JWT_PRIVATE_KEY_PATH=/app/secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=/app/secrets/jwt_public.pem
# JWT_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# JWT_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7
JWT_ISSUER=gamehub-auth

# --- Public / internal ports ---
AUTH_SERVICE_PORT=8001
GAME_SESSION_PORT=8002
PAYMENT_GATEWAY_PORT=8003
WALLET_SERVICE_PORT=8004
TRADER_POOL_PORT=8005

# --- Internal service URLs ---
AUTH_SERVICE_URL=http://127.0.0.1:8001
PAYMENT_GATEWAY_URL=http://127.0.0.1:8003
WALLET_SERVICE_URL=http://127.0.0.1:8004
TRADER_POOL_URL=http://127.0.0.1:8005
INTERNAL_SERVICE_KEY=dev-internal-key

# --- CORS / email ---
CORS_ALLOWED_ORIGINS=*
RESEND_API_KEY=
EMAIL_FROM=Glory Grid Support <support@glorygrid.local>
PASSWORD_RESET_URL=https://glorygrid.local/reset-password
PASSWORD_RESET_TTL_MINUTES=30

# --- OAuth Providers ---
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://api.gamehub.local/auth/google/callback
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_CALLBACK_URL=https://api.gamehub.local/auth/facebook/callback
APPLE_CLIENT_ID=com.yourcompany.gamehub
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=/app/secrets/apple_auth.p8
APPLE_CALLBACK_URL=https://api.gamehub.local/auth/apple/callback
APPLE_AUTH_PRIVATE_KEY=

# --- OTP / SMS ---
HUBTEL_SMS_CLIENT_ID=your_hubtel_sms_client_id
HUBTEL_SMS_CLIENT_SECRET=your_hubtel_sms_client_secret
HUBTEL_SMS_FROM=Glory Grid
OTP_TTL_MINUTES=5
OTP_LENGTH=6

# --- Mobile Money (Flutterwave) ---
FLUTTERWAVE_MODE=test
FLUTTERWAVE_BASE_URL=https://api.flutterwave.com
FLUTTERWAVE_TRANSFERS_BASE_URL=
FLUTTERWAVE_TEST_PUBLIC_KEY=replace_me
FLUTTERWAVE_TEST_SECRET_KEY=replace_me
FLUTTERWAVE_TEST_ENCRYPTION_KEY=replace_me
FLUTTERWAVE_LIVE_PUBLIC_KEY=
FLUTTERWAVE_LIVE_SECRET_KEY=
FLUTTERWAVE_LIVE_ENCRYPTION_KEY=
FLUTTERWAVE_WEBHOOK_SECRET=change_me
FLUTTERWAVE_MOMO_CALLBACK_URL=https://api.gamehub.io/webhooks/payment/flutterwave
FLUTTERWAVE_TRANSFER_CALLBACK_URL=https://api.gamehub.io/webhooks/payment/flutterwave/withdrawal
MOMO_ALLOWED_CHANNELS=mtn-gh,vodafone-gh,airteltigo-gh
MOMO_DEFAULT_CURRENCY=GHS

# --- Hubtel Mobile Money (optional) ---
HUBTEL_PAYMENT_CLIENT_ID=
HUBTEL_PAYMENT_CLIENT_SECRET=
HUBTEL_PAYMENT_ACCOUNT_NUMBER=
HUBTEL_PRIMARY_CALLBACK_URL=https://api.gamehub.io/webhooks/payment/hubtel
HUBTEL_CHECKOUT_URL=https://checkout.hubtel.com/api/checkout/initiate
HUBTEL_SEND_MONEY_URL=https://api.hubtel.com/v2/merchant/send-money
HUBTEL_WEBHOOK_SECRET=
HUBTEL_SUPPORTED_CHANNELS=mtn-gh,vodafone-gh,airteltigo-gh

# --- Crypto Deposits (Tatum) ---
TATUM_API_KEY=replace_me
TATUM_WEBHOOK_SECRET=change_me
TATUM_BASE_URL=https://api.tatum.io
TATUM_TESTNET=false
TATUM_BTC_XPUB=replace_me
TATUM_ETH_XPUB=replace_me
TATUM_TRON_XPUB=replace_me
CRYPTO_WATCHER_INTERVAL_SECONDS=60
CRYPTO_WEBHOOK_URL=https://api.gamehub.io/webhooks/payment/crypto

# --- Deriv ---
DERIV_APP_ID=replace_me
DERIV_WS_URL=wss://ws.binaryws.com/websockets/v3
DERIV_ACCOUNT_1_TOKEN=replace_me

# --- Gameplay / settlement ---
GAME_STALE_SWEEP_INTERVAL_SECONDS=20
GAME_STALE_REFUND_SECONDS=90
BOUNCE_RATE=0.0
PROFIT_TARGET_USD=0.0
WIN_RAKE_RATE=0.0
PAYOUT_MULTIPLIER=1.9
DEPOSIT_FEE_RATE=0.0
WITHDRAWAL_FEE_RATE=0.05
